{
  "name": "@corti/ai-sdk-adapter",
  "version": "0.1.1",
  "description": "Corti AI SDK adapter for Vercel AI SDK, integrating with Corti's A2A agents API",
  "keywords": [
    "ai",
    "ai-sdk",
    "vercel",
    "corti",
    "a2a",
    "agents",
    "llm",
    "language-model"
  ],
  "author": "Corti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corticph/ai-sdk-adapter.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.20.0",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:clean": "del-cli dist && pnpm run build",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write .",
    "prepublishOnly": "pnpm run build:clean && pnpm run type-check && pnpm test"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.0.0",
    "del-cli": "^5.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@a2a-js/sdk": "*",
    "ai": ">=6.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@a2a-js/sdk": {
      "optional": false
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}